# Shopify Storefront API
# Example domain: poppy-joy.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API public access token.
# This is different from an Admin API token and should not start with `shpat_`.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Keep this pinned so Storefront API behavior stays predictable.
SHOPIFY_API_VERSION=2026-01

# Shopify Admin API
# Required only for local scripts that create/update products, metafield definitions,
# product metafields, inventory, and media. Never expose this to the browser.
#
# Option A: Direct Admin API access token, usually starts with `shpat_`.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Option B: Dev Dashboard client credentials grant.
# Use this when Shopify does not show a copyable Admin API token.
# Example shop value: `1d95cp-f1` for `1d95cp-f1.myshopify.com`.
SHOPIFY_SHOP=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

SHOPIFY_ADMIN_API_VERSION=2025-01

# Hero media (Shopify URLs, used on homepage)
NEXT_PUBLIC_SHOPIFY_HERO_VIDEO_URL=
NEXT_PUBLIC_SHOPIFY_HERO_VIDEO_POSTER_URL=
